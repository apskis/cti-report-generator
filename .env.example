# Local dev environment for scripts/run_local.py.
# Copy this file to `.env` (which is gitignored) and fill in / adjust values.
# run_local.py auto-loads `.env`; already-exported shell vars take precedence.
#
#   cp .env.example .env
#
# These persist across terminal sessions (unlike `export`/`$env:`), so you only
# set them once for local testing.

# Key Vault the collectors + OpenAI credentials are pulled from (for --real runs).
KEY_VAULT_URL=https://kv-cti-rep-prod.vault.azure.net/

# --- Azure OpenAI model selection ---
# Deployment name (NOT the model id) as created in Foundry.
AZURE_OPENAI_DEPLOYMENT=gpt-5.6-sol
# REST API version from the model's "Use this model" sample.
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Set to "default" to OMIT the parameter (reasoning models reject custom values);
# use a number (e.g. 0.1 / 789) to send an explicit value.
AZURE_OPENAI_TEMPERATURE=default
AZURE_OPENAI_SEED=default

# --- OSINT full-text extraction (opt-in) ---
# When "true", each OSINT article URL is fetched and its body extracted with
# trafilatura (stored as full_text) so the AI sees the whole article instead of the
# short RSS summary. Off by default. Requires the 'trafilatura' dependency.
# ENABLE_OSINT_FULLTEXT=true
# OSINT_FULLTEXT_MAX_CHARS=4000   # per-article body cap (token/cost control)
